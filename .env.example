# Local faster-whisper config (no API key needed).
VOICE_LANGUAGE=zh
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
VOICE_AUTO_SUBMIT=1

# Sentinel appended to every transcription so Claude can detect voice
# input and tolerate ASR errors. Set to empty to disable.
VOICE_MARKER= <voice>
